# Project Settings
PROJECT_NAME="CrediShield AI"

# Database Connection (MySQL required)
# Example: mysql+pymysql://[user]:[password]@[host]:3306/[dbname]
DATABASE_URL="mysql+pymysql://root:password@localhost:3306/credishield"

# JWT Authentication
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="supersecretkey_replace_in_production_1234567890"

# Task Queue & Caching (Redis)
REDIS_URL="redis://localhost:6379/0"

# AWS S3 Storage for Reports (Optional, fallback to local static reports serving if left empty)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME="credishield-reports"
